# =============================================================================
# BitNet b1.58 2B — Variáveis de ambiente
#
# No Coolify: adicione estas variáveis no painel Environment Variables
# Localmente: copie para .env e ajuste os valores
# =============================================================================

# Threads de CPU dedicadas ao BitNet
# Regra: total de vCores do VPS - 1
# Exemplos: VPS 2 vCores → 1 | VPS 4 vCores → 3 | VPS 8 vCores → 6
BITNET_THREADS=3

# Contexto máximo em tokens
# 4096 é o máximo suportado pelo modelo
# Reduza para 2048 se tiver pressão de memória
BITNET_CTX=4096

# Porta interna do servidor (não precisa mudar)
BITNET_PORT=8080

# Temperatura da geração
# 0.0 = determinístico (ideal para classificação/triagem)
# 0.7 = mais criativo (para respostas conversacionais)
BITNET_TEMPERATURE=0.0
